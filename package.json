{
  "name": "dreamplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:staged": "prettier --write",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "analyze": "ANALYZE=true npm run build",
    "analyze:server": "BUNDLE_ANALYZE=server npm run build",
    "analyze:browser": "BUNDLE_ANALYZE=browser npm run build",
    "perf": "npm run build && npm run analyze",
    "perf:ci": "NODE_ENV=production npm run perf",
    "docker:build": "docker build -t dreamplace .",
    "docker:dev": "docker-compose --profile dev up",
    "docker:prod": "docker-compose up",
    "docker:clean": "docker system prune -af"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.1.0",
    "@emotion/react": "^11.13.3",
    "@tanstack/react-query": "^5.85.0",
    "@tanstack/react-query-devtools": "^5.85.0",
    "axios": "^1.11.0",
    "firebase": "^11.0.1",
    "framer-motion": "^11.11.11",
    "immer": "^10.1.1",
    "lenis": "^1.1.15",
    "next": "14.2.15",
    "next-themes": "^0.4.3",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.3.0",
    "react-scroll-parallax": "^3.4.5",
    "react-spring": "^9.7.4",
    "react-spring-3d-carousel": "^1.3.4",
    "sharp": "^0.33.5",
    "swiper": "^11.1.14",
    "uuid": "^11.0.2",
    "zustand": "^5.0.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --ignore-pattern '.storybook/**'",
      "prettier --write"
    ],
    "*.{json,css,scss,md,mdx}": [
      "prettier --write"
    ],
    "*.{yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@next/bundle-analyzer": "^15.4.6",
    "@next/env": "^15.4.6",
    "@storybook/addon-docs": "^9.1.2",
    "@storybook/addon-onboarding": "^9.1.2",
    "@storybook/nextjs": "^9.1.2",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "cross-fetch": "^4.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "eslint-plugin-storybook": "^9.1.2",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "lint-staged": "^16.1.5",
    "msw": "^2.10.4",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "storybook": "^9.1.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "undici": "^7.13.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "whatwg-fetch": "^3.6.20"
  }
}
