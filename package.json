{
  "name": "dreamplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:staged": "prettier --write",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.1.0",
    "@emotion/react": "^11.13.3",
    "firebase": "^11.0.1",
    "framer-motion": "^11.11.11",
    "lenis": "^1.1.15",
    "next": "14.2.15",
    "next-themes": "^0.4.3",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.3.0",
    "react-scroll-parallax": "^3.4.5",
    "react-spring": "^9.7.4",
    "react-spring-3d-carousel": "^1.3.4",
    "sharp": "^0.33.5",
    "swiper": "^11.1.14",
    "uuid": "^11.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
