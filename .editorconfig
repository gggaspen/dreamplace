# EditorConfig Configuration for DreamPlace
# This file ensures consistent coding styles between different editors and IDEs
# For more information, visit: https://editorconfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# TypeScript and JavaScript files
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2
quote_type = single

# JSON files
[*.{json,jsonc}]
indent_size = 2
insert_final_newline = false

# CSS, SCSS, and style files
[*.{css,scss,sass,less}]
indent_size = 2

# HTML and template files
[*.{html,htm,vue,svelte}]
indent_size = 2

# Markdown files
[*.{md,mdx}]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Configuration files
[*.{toml,ini,cfg,conf}]
indent_size = 2

# Shell scripts
[*.{sh,bash,zsh}]
indent_size = 2
end_of_line = lf

# Python files (if any are added later)
[*.py]
indent_size = 4
max_line_length = 88

# Makefile
[Makefile]
indent_style = tab
indent_size = 4

# Package files
[package.json]
indent_size = 2

# Docker files
[{Dockerfile,Dockerfile.*,.dockerignore}]
indent_size = 2

# Git files
[.gitignore]
indent_size = 2